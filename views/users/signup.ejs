<% layout("layouts/boilerplate") %>
<div class="row mt-3">
    <div class="col-6 offset-3">
        <h2>Sign Up on Wanderlust</h2>
        <br>
        <form method="POST" action="/signup" class="needs-validation" novalidate>
            <div class="mb-3"> 
                <label for="username" class="form-label">Username</label>
                <input name="username" type="text" id="username" class="form-control" required>
                <div class="valid-feedback">Username looks good!</div>
            </div>

            <div class="mb-3"> 
                <label for="useremail" class="form-label">Email</label>
                <input name="email" type="email" id="useremail" class="form-control" required>
            </div>

            <div class="mb-3"> 
                <label for="password" class="form-label">Password</label>
                <input name="password" type="password" id="password" class="form-control" required>
                <div class="valid-feedback">stronger password!</div>
            </div>

            <button class="btn btn-success">signUp</button>
        </form>
    </div>
</div>